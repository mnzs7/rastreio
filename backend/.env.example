# Database
DATABASE_URL="postgresql://rastreio:rastreio123@localhost:5432/rastreio_db"

# JWT
JWT_SECRET="sua-chave-secreta-super-segura-mude-em-producao"
JWT_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Frontend URL (para links nos emails)
FRONTEND_URL=http://localhost:5173

# SMTP (opcional — se não configurado, emails são apenas logados no console)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app
# SMTP_FROM=noreply@rastreio.com
